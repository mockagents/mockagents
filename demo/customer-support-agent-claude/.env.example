# Copy to .env and adjust. Used when running the demo app directly (not in Docker).

# MockAgents server ROOT — NOTE: no /v1 suffix. The Claude CLI and the Anthropic
# SDK append the path (/v1/messages) themselves.
MOCKAGENTS_BASE_URL=http://localhost:8080

# Single-tenant mode: any non-empty value (sent as the x-api-key header).
# Multi-tenant mode: a tenant API key, so MockAgents resolves the tenant for
# quota + cost tracking.
MOCKAGENTS_API_KEY=mock-key
