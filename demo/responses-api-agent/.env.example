# Copy to .env and adjust. Used when running the demo app directly.

# Where MockAgents is listening (note the /v1 suffix for the OpenAI surface).
MOCKAGENTS_BASE_URL=http://localhost:8080/v1

# Single-tenant mode: any non-empty value works.
# Multi-tenant mode: set this to a tenant API key so MockAgents resolves the
# tenant and applies quota + cost tracking.
MOCKAGENTS_API_KEY=mock-key

# How many times the OpenAI client auto-retries 429/5xx.
OPENAI_MAX_RETRIES=5
