# Copy to .env and adjust. Used when running the demo app directly (not in Docker).

# MockAgents server ROOT — NOTE: no /v1 suffix. The native Gemini path uses it
# directly (the genai client appends /v1beta/...); the LiteLLM bridge appends /v1.
MOCKAGENTS_BASE_URL=http://localhost:8080

# Single-tenant mode: any non-empty value.
# Multi-tenant mode: a tenant API key, so MockAgents resolves the tenant for
# quota + cost. NOTE: on the Gemini surface, pass it as Authorization: Bearer
# (the genai client's x-goog-api-key header is not used for tenant resolution) —
# see TESTING.md.
MOCKAGENTS_API_KEY=mock-key
