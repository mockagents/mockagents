{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mockagents.dev/schema/v1/pipeline.json",
  "title": "MockAgents Pipeline Definition",
  "description": "Declarative multi-agent topology for MockAgents.",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": { "type": "string", "const": "mockagents/v1" },
    "kind": { "type": "string", "const": "Pipeline" },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$", "maxLength": 63 },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "spec": {
      "type": "object",
      "required": ["topology", "agents"],
      "additionalProperties": false,
      "properties": {
        "topology": {
          "type": "string",
          "enum": ["sequential", "parallel", "graph"],
          "description": "How the agents are wired together."
        },
        "agents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "ref"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "description": "Unique node id within this pipeline." },
              "ref": { "type": "string", "description": "metadata.name of a loaded agent." }
            }
          }
        },
        "edges": {
          "type": "array",
          "description": "Directed edges between nodes (graph topology only).",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "additionalProperties": false,
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "when_contains": {
                "type": "string",
                "description": "If set, the edge fires only when the upstream node's output contains this value as a case-sensitive substring (not an exact or word-boundary match). For example \"no\" also matches output \"another\"."
              }
            }
          }
        }
      }
    }
  }
}
